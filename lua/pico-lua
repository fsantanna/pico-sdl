#!/bin/sh

# pico-sdl-lua /a/b/c/x.lua

PICO="$(dirname "$(realpath "$0")")/.."   # pico-sdl root

if [ "$1" = "--version" ]; then
    VERSION=""
    for file in "$PICO/lua"/pico-sdl-*.rockspec; do
        if [ -f "$file" ]; then
            VERSION="v$(basename "$file" | sed -E 's/.*pico-sdl-(.*)-[0-9]+\.rockspec/\1/')"
            break
        fi
    done
    if [ -z "$VERSION" ] && [ -f "$PICO/HISTORY.md" ]; then
        VERSION=$(grep -m 1 '^v[0-9]' "$PICO/HISTORY.md" | awk '{print $1}')
    fi
    echo "pico-lua ${VERSION:-unknown}"
    exit 0
fi

LUA=lua5.4
DIR=$(dirname -- "$1")  # /a/b/c
EXE=$(basename -- "$1") # x.lua

cd $DIR/
$LUA -lpico $EXE
